generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js Models ───────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  wallets       Wallet[]
  holdings      AssetHolding[]
  transactions  Transaction[]
  depositRequests  DepositRequest[]
  withdrawalRequests WithdrawalRequest[]
  tradeOrders   TradeOrder[]
  supportTickets SupportTicket[]
  notifications Notification[]
  watchlistItems WatchlistItem[]
  verifications Verification[]
  adminActions  AdminActionLog[] @relation("AdminActions")
  targetActions AdminActionLog[] @relation("TargetActions")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── User Profile ─────────────────────────────────────────
model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  firstName   String?
  lastName    String?
  phone       String?
  country     String?
  address     String?
  city        String?
  zipCode     String?
  dateOfBirth DateTime?
  avatarUrl   String?
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ─── KYC / Verification ───────────────────────────────────
model Verification {
  id          String           @id @default(cuid())
  userId      String
  type        VerificationType @default(IDENTITY)
  status      VerificationStatus @default(PENDING)
  documentType String?
  frontUrl    String?
  backUrl     String?
  selfieUrl   String?
  notes       String?
  reviewedBy  String?
  reviewedAt  DateTime?
  submittedAt DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verifications")
}

// ─── Wallet ───────────────────────────────────────────────
model Wallet {
  id        String   @id @default(cuid())
  userId    String
  currency  String   // USD, BTC, ETH, USDT
  balance   Decimal  @default(0) @db.Decimal(20, 8)
  address   String?  // simulated wallet address
  isLocked  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, currency])
  @@map("wallets")
}

// ─── Asset Holdings ───────────────────────────────────────
model AssetHolding {
  id           String   @id @default(cuid())
  userId       String
  assetId      String
  quantity     Decimal  @default(0) @db.Decimal(20, 8)
  avgBuyPrice  Decimal  @default(0) @db.Decimal(20, 8)
  totalInvested Decimal @default(0) @db.Decimal(20, 8)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset MarketAsset @relation(fields: [assetId], references: [id])

  @@unique([userId, assetId])
  @@map("asset_holdings")
}

// ─── Market Assets ────────────────────────────────────────
model MarketAsset {
  id            String   @id @default(cuid())
  symbol        String   @unique
  name          String
  logoUrl       String?
  currentPrice  Decimal  @db.Decimal(20, 8)
  priceChange24h Decimal @default(0) @db.Decimal(10, 4)
  marketCap     Decimal? @db.Decimal(30, 2)
  volume24h     Decimal? @db.Decimal(30, 2)
  circulatingSupply Decimal? @db.Decimal(30, 8)
  description   String?
  isActive      Boolean  @default(true)
  rank          Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  holdings     AssetHolding[]
  watchlistItems WatchlistItem[]
  tradeOrders  TradeOrder[]

  @@map("market_assets")
}

// ─── Watchlist ────────────────────────────────────────────
model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  assetId   String
  createdAt DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset MarketAsset @relation(fields: [assetId], references: [id])

  @@unique([userId, assetId])
  @@map("watchlist_items")
}

// ─── Transactions ─────────────────────────────────────────
model Transaction {
  id          String          @id @default(cuid())
  userId      String
  type        TransactionType
  currency    String
  amount      Decimal         @db.Decimal(20, 8)
  fee         Decimal         @default(0) @db.Decimal(20, 8)
  status      TxStatus        @default(COMPLETED)
  description String?
  reference   String?         @unique @default(cuid())
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

// ─── Deposit Requests ─────────────────────────────────────
model DepositRequest {
  id            String        @id @default(cuid())
  userId        String
  currency      String
  amount        Decimal       @db.Decimal(20, 8)
  method        String        @default("Bank Transfer")
  status        RequestStatus @default(PENDING)
  proofUrl      String?
  notes         String?
  adminNotes    String?
  processedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("deposit_requests")
}

// ─── Withdrawal Requests ──────────────────────────────────
model WithdrawalRequest {
  id            String        @id @default(cuid())
  userId        String
  currency      String
  amount        Decimal       @db.Decimal(20, 8)
  method        String        @default("Bank Transfer")
  destination   String?
  status        RequestStatus @default(PENDING)
  notes         String?
  adminNotes    String?
  processedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("withdrawal_requests")
}

// ─── Trade Orders ─────────────────────────────────────────
model TradeOrder {
  id          String      @id @default(cuid())
  userId      String
  assetId     String
  type        TradeType
  side        TradeSide
  quantity    Decimal     @db.Decimal(20, 8)
  price       Decimal     @db.Decimal(20, 8)
  total       Decimal     @db.Decimal(20, 8)
  fee         Decimal     @default(0) @db.Decimal(20, 8)
  status      TradeStatus @default(FILLED)
  notes       String?
  executedAt  DateTime    @default(now())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset MarketAsset @relation(fields: [assetId], references: [id])

  @@map("trade_orders")
}

// ─── Support Tickets ──────────────────────────────────────
model SupportTicket {
  id          String        @id @default(cuid())
  userId      String
  subject     String
  category    String        @default("General")
  status      TicketStatus  @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@map("support_tickets")
}

model SupportMessage {
  id          String   @id @default(cuid())
  ticketId    String
  senderId    String
  senderRole  Role     @default(USER)
  content     String
  attachmentUrl String?
  createdAt   DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("support_messages")
}

// ─── Notifications ────────────────────────────────────────
model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── Admin Action Log ─────────────────────────────────────
model AdminActionLog {
  id          String   @id @default(cuid())
  adminId     String
  targetId    String?
  action      String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())

  admin  User  @relation("AdminActions", fields: [adminId], references: [id])
  target User? @relation("TargetActions", fields: [targetId], references: [id])

  @@map("admin_action_logs")
}

// ─── Site Config ──────────────────────────────────────────
model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("site_configs")
}

// ─── Enums ────────────────────────────────────────────────
enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  FROZEN
  RESTRICTED
  SUSPENDED
}

enum VerificationType {
  IDENTITY
  ADDRESS
  ENHANCED
}

enum VerificationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BUY
  SELL
  FEE
  BONUS
  ADJUSTMENT
}

enum TxStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSING
}

enum TradeType {
  MARKET
  LIMIT
}

enum TradeSide {
  BUY
  SELL
}

enum TradeStatus {
  PENDING
  FILLED
  CANCELLED
  PARTIAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  TRADE
  DEPOSIT
  WITHDRAWAL
  VERIFICATION
  SUPPORT
}
