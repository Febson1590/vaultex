generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js Models ───────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  wallets       Wallet[]
  holdings      AssetHolding[]
  transactions  Transaction[]
  depositRequests  DepositRequest[]
  withdrawalRequests WithdrawalRequest[]
  tradeOrders   TradeOrder[]
  supportTickets SupportTicket[]
  notifications Notification[]
  watchlistItems WatchlistItem[]
  verifications Verification[]
  adminActions  AdminActionLog[] @relation("AdminActions")
  targetActions AdminActionLog[] @relation("TargetActions")
  investment    UserInvestment?
  copyTrades    UserCopyTrade[]
  activityLogs  ActivityLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── User Profile ─────────────────────────────────────────
model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  firstName   String?
  lastName    String?
  phone       String?
  country     String?
  address     String?
  city        String?
  zipCode     String?
  dateOfBirth DateTime?
  avatarUrl   String?
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ─── KYC / Verification ───────────────────────────────────
model Verification {
  id          String           @id @default(cuid())
  userId      String
  type        VerificationType @default(IDENTITY)
  status      VerificationStatus @default(PENDING)
  documentType String?
  frontUrl    String?
  backUrl     String?
  selfieUrl   String?
  notes       String?
  reviewedBy  String?
  reviewedAt  DateTime?
  submittedAt DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verifications")
}

// ─── Wallet ───────────────────────────────────────────────
model Wallet {
  id        String   @id @default(cuid())
  userId    String
  currency  String   // USD, BTC, ETH, USDT
  balance   Decimal  @default(0) @db.Decimal(20, 8)
  address   String?  // simulated wallet address
  isLocked  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, currency])
  @@map("wallets")
}

// ─── Asset Holdings ───────────────────────────────────────
model AssetHolding {
  id           String   @id @default(cuid())
  userId       String
  assetId      String
  quantity     Decimal  @default(0) @db.Decimal(20, 8)
  avgBuyPrice  Decimal  @default(0) @db.Decimal(20, 8)
  totalInvested Decimal @default(0) @db.Decimal(20, 8)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset MarketAsset @relation(fields: [assetId], references: [id])

  @@unique([userId, assetId])
  @@map("asset_holdings")
}

// ─── Market Assets ────────────────────────────────────────
model MarketAsset {
  id            String   @id @default(cuid())
  symbol        String   @unique
  name          String
  logoUrl       String?
  currentPrice  Decimal  @db.Decimal(20, 8)
  priceChange24h Decimal @default(0) @db.Decimal(10, 4)
  marketCap     Decimal? @db.Decimal(30, 2)
  volume24h     Decimal? @db.Decimal(30, 2)
  circulatingSupply Decimal? @db.Decimal(30, 8)
  description   String?
  isActive      Boolean  @default(true)
  rank          Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  holdings     AssetHolding[]
  watchlistItems WatchlistItem[]
  tradeOrders  TradeOrder[]

  @@map("market_assets")
}

// ─── Watchlist ────────────────────────────────────────────
model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  assetId   String
  createdAt DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset MarketAsset @relation(fields: [assetId], references: [id])

  @@unique([userId, assetId])
  @@map("watchlist_items")
}

// ─── Transactions ─────────────────────────────────────────
model Transaction {
  id          String          @id @default(cuid())
  userId      String
  type        TransactionType
  currency    String
  amount      Decimal         @db.Decimal(20, 8)
  fee         Decimal         @default(0) @db.Decimal(20, 8)
  status      TxStatus        @default(COMPLETED)
  description String?
  reference   String?         @unique @default(cuid())
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

// ─── Deposit Requests ─────────────────────────────────────
model DepositRequest {
  id            String        @id @default(cuid())
  userId        String
  currency      String                                   // Legacy — matches the crypto symbol, kept for older records
  amount        Decimal       @db.Decimal(20, 8)         // Primary amount, always in USD
  method        String        @default("Bank Transfer")
  status        RequestStatus @default(PENDING)
  proofUrl      String?
  txHash        String?
  walletId      String?
  notes         String?
  adminNotes    String?
  processedAt   DateTime?
  // Dual-amount conversion snapshot captured at submission time ──────────
  cryptoAmount  Decimal?      @db.Decimal(30, 10)        // e.g. 0.005 BTC
  cryptoSymbol  String?                                  // e.g. "BTC"
  cryptoNetwork String?                                  // e.g. "TRC20" / "Bitcoin"
  exchangeRate  Decimal?      @db.Decimal(20, 8)         // USD price per crypto unit at submission
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("deposit_requests")
}

// ─── Admin-controlled deposit wallets ─────────────────────
model DepositWallet {
  id           String   @id @default(cuid())
  asset        String
  network      String?
  address      String
  label        String
  minDeposit   Decimal? @db.Decimal(20, 8)   // per-wallet minimum (USD)
  instructions String?                       // optional admin note shown to user
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("deposit_wallets")
}

// ─── Withdrawal Requests ──────────────────────────────────
model WithdrawalRequest {
  id            String        @id @default(cuid())
  userId        String
  currency      String                                   // Legacy — crypto symbol, kept for older records
  amount        Decimal       @db.Decimal(20, 8)         // Primary amount, always in USD
  method        String        @default("Bank Transfer")  // Network label for crypto (TRC20, ERC20…)
  destination   String?
  status        RequestStatus @default(PENDING)
  notes         String?
  adminNotes    String?
  processedAt   DateTime?
  // Dual-amount conversion snapshot captured at submission time ──────────
  cryptoAmount  Decimal?      @db.Decimal(30, 10)
  cryptoSymbol  String?
  cryptoNetwork String?
  exchangeRate  Decimal?      @db.Decimal(20, 8)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("withdrawal_requests")
}

// ─── Trade Orders ─────────────────────────────────────────
model TradeOrder {
  id          String      @id @default(cuid())
  userId      String
  assetId     String
  type        TradeType
  side        TradeSide
  quantity    Decimal     @db.Decimal(20, 8)
  price       Decimal     @db.Decimal(20, 8)
  total       Decimal     @db.Decimal(20, 8)
  fee         Decimal     @default(0) @db.Decimal(20, 8)
  status      TradeStatus @default(FILLED)
  notes       String?
  executedAt  DateTime    @default(now())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset MarketAsset @relation(fields: [assetId], references: [id])

  @@map("trade_orders")
}

// ─── Support Tickets ──────────────────────────────────────
model SupportTicket {
  id          String        @id @default(cuid())
  userId      String
  subject     String
  category    String        @default("General")
  status      TicketStatus  @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@map("support_tickets")
}

model SupportMessage {
  id          String   @id @default(cuid())
  ticketId    String
  senderId    String
  senderRole  Role     @default(USER)
  content     String
  attachmentUrl String?
  createdAt   DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("support_messages")
}

// ─── Notifications ────────────────────────────────────────
model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── Admin Action Log ─────────────────────────────────────
model AdminActionLog {
  id          String   @id @default(cuid())
  adminId     String
  targetId    String?
  action      String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())

  admin  User  @relation("AdminActions", fields: [adminId], references: [id])
  target User? @relation("TargetActions", fields: [targetId], references: [id])

  @@map("admin_action_logs")
}

// ─── Site Config ──────────────────────────────────────────
model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("site_configs")
}

// ─── Investment Plans ─────────────────────────────────────
model InvestmentPlan {
  id               String   @id @default(cuid())
  name             String
  description      String?
  minAmount        Decimal  @default(100) @db.Decimal(20, 2)
  maxAmount        Decimal? @db.Decimal(20, 2)           // null = unlimited
  minProfit        Decimal  @default(0.5)  @db.Decimal(6, 4)  // e.g. 0.5 = 0.5%
  maxProfit        Decimal  @default(1.5)  @db.Decimal(6, 4)
  profitInterval   Int      @default(60)   // min seconds between profit credits
  maxInterval      Int      @default(60)   // max seconds between profit credits
  /** Advertised investment horizon — how long the plan runs, in HOURS.
      Used on the public plan cards; the profit-credit scheduler itself still
      uses `profitInterval` for cycle cadence. Nullable for legacy plans.
      Stored in the DB under the legacy `minDurationDays`/`maxDurationDays`
      column names (unchanged to avoid a destructive migration); the field
      names here are the source of truth for the unit. */
  minDurationHours Int?     @map("minDurationDays")
  maxDurationHours Int?     @map("maxDurationDays")
  isActive         Boolean  @default(true)
  isPopular        Boolean  @default(false) // show "Most Popular" badge (only one plan should have this)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  userInvestments  UserInvestment[]

  @@map("investment_plans")
}

model UserInvestment {
  id               String           @id @default(cuid())
  userId           String           @unique
  planId           String?
  planName         String
  amount           Decimal          @db.Decimal(20, 2)
  totalEarned      Decimal          @default(0) @db.Decimal(20, 2)
  minProfit        Decimal          @db.Decimal(6, 4)
  maxProfit        Decimal          @db.Decimal(6, 4)
  profitInterval   Int              @default(60)
  maxInterval      Int              @default(60)
  status           InvestmentStatus @default(ACTIVE)
  lastProfitAt     DateTime?
  nextProfitAt     DateTime?
  startedAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan  InvestmentPlan?  @relation(fields: [planId], references: [id])

  @@map("user_investments")
}

// ─── Copy Traders ─────────────────────────────────────────
model CopyTrader {
  id              String   @id @default(cuid())
  name            String
  avatarUrl       String?
  country         String?  // ISO alpha-2 code, e.g. "US", "GB" — used for flag
  specialty       String?
  description     String?
  winRate         Decimal  @default(0) @db.Decimal(5, 2)
  totalROI        Decimal  @default(0) @db.Decimal(8, 2)
  performance30d  Decimal  @default(0) @db.Decimal(8, 2)  // % return over last 30 days
  riskLevel       String   @default("MEDIUM")             // LOW | MEDIUM | HIGH
  followers       Int      @default(0)
  totalTrades     Int      @default(0)
  successfulTrades Int     @default(0)
  failedTrades    Int      @default(0)
  maxDrawdown     Decimal  @default(0) @db.Decimal(6, 2)  // negative % e.g. -8.00
  minCopyAmount   Decimal  @default(100) @db.Decimal(20, 2)
  maxCopyAmount   Decimal? @db.Decimal(20, 2)             // null = unlimited
  profitInterval  Int      @default(60)  // min seconds between profit credits
  maxInterval     Int      @default(60)  // max seconds between profit credits
  minProfit       Decimal  @default(0.3) @db.Decimal(6, 4)
  maxProfit       Decimal  @default(1.2) @db.Decimal(6, 4)
  isActive        Boolean  @default(true)
  isSeeded        Boolean  @default(false)               // true if auto-created by the default-seed action
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userCopyTrades  UserCopyTrade[]

  @@map("copy_traders")
}

model UserCopyTrade {
  id           String          @id @default(cuid())
  userId       String
  traderId     String
  traderName   String
  amount       Decimal         @db.Decimal(20, 2)
  totalEarned  Decimal         @default(0) @db.Decimal(20, 2)
  minProfit    Decimal         @db.Decimal(6, 4)
  maxProfit    Decimal         @db.Decimal(6, 4)
  profitInterval Int           @default(60)
  maxInterval  Int           @default(60)
  status       CopyTradeStatus @default(ACTIVE)
  lastProfitAt DateTime?
  nextProfitAt DateTime?
  startedAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  trader  CopyTrader @relation(fields: [traderId], references: [id])

  @@map("user_copy_trades")
}

// ─── Email OTP ────────────────────────────────────────────
model OtpCode {
  id         String   @id @default(cuid())
  identifier String   // email address
  code       String   // 6-digit code
  type       OtpType
  expires    DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([identifier, type])
  @@map("otp_codes")
}

// ─── Activity Log ─────────────────────────────────────────
model ActivityLog {
  id        String       @id @default(cuid())
  userId    String
  type      ActivityType
  title     String
  amount    Decimal?     @db.Decimal(20, 2)
  currency  String       @default("USD")
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

// ─── Enums ────────────────────────────────────────────────
enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  FROZEN
  RESTRICTED
  SUSPENDED
}

enum VerificationType {
  IDENTITY
  ADDRESS
  ENHANCED
}

enum VerificationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BUY
  SELL
  FEE
  BONUS
  ADJUSTMENT
}

enum TxStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSING
}

enum TradeType {
  MARKET
  LIMIT
}

enum TradeSide {
  BUY
  SELL
}

enum TradeStatus {
  PENDING
  FILLED
  CANCELLED
  PARTIAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  TRADE
  DEPOSIT
  WITHDRAWAL
  VERIFICATION
  SUPPORT
  SECURITY
}

enum InvestmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum CopyTradeStatus {
  ACTIVE
  PAUSED
  STOPPED
}

enum OtpType {
  REGISTER
  LOGIN
}

enum ActivityType {
  INVESTMENT_STARTED
  INVESTMENT_PROFIT
  INVESTMENT_PAUSED
  INVESTMENT_RESUMED
  INVESTMENT_FUNDS_ADDED
  INVESTMENT_UPGRADED
  INVESTMENT_CANCELLED
  COPY_TRADE_STARTED
  COPY_TRADE_PROFIT
  COPY_TRADE_STOPPED
  COPY_TRADE_PAUSED
}
